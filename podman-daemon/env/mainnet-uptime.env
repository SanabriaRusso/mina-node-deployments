MINA_IMAGE=europe-west3-docker.pkg.dev/o1labs-192920/euro-docker-repo/mina-daemon:3.3.0-beta1-compatible-532a749-bookworm-mainnet-arm64
PEER=/dns4/seed-1.mainnet.gcp.o1test.net/tcp/10003/p2p/12D3KooWCa1d7G3SkRxy846qTvdAFX69NnoYZ32orWVLqJcDVGHW
RUNTIME_CONFIG=
PEER_LIST_URL=
NODE_STATUS_URL=
NODE_ERROR_URL=
# Uptime Replicator - set this to the Cloud Function URL after deploy
# Get it via: cd ~/github/gitops-infrastructure/platform/gcloud/uptime-replicator && OPERATION=output ./run.sh | jq -r '.function_url.value'
UPTIME_URL=REPLACE_WITH_FUNCTION_URL/api/v1/mainnet/submit
# Path to the submitter private key file (mounted into container)
UPTIME_SUBMITTER_KEY_PATH=./shared/uptime-submitter-key
